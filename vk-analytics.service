[Unit]
Description=VK Analytics Dashboard
After=network.target

[Service]
User=root
WorkingDirectory=/home/forge/vk.nedicom.ru
ExecStart=/usr/local/bin/gunicorn -w 2 -b 0.0.0.0:8001 app:app
Restart=always
RestartSec=5
EnvironmentFile=/home/forge/vk.nedicom.ru/.env

[Install]
WantedBy=multi-user.target
